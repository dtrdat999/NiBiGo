# ─────────────────────────────────────────────────────────────
# NiBiGo AI Planner — biến môi trường mẫu.
# Copy file này thành .env.local rồi điền giá trị thật.
# KHÔNG commit .env.local. KHÔNG để lộ service role / API key.
# ─────────────────────────────────────────────────────────────

# Supabase (public — đi kèm RLS, được phép lộ ở client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — CHỈ dùng server-side. TUYỆT ĐỐI không import vào client.
SUPABASE_SERVICE_ROLE_KEY=

# AI provider (MVP mặc định: openai)
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
# (để trống nếu chưa dùng Gemini)
GEMINI_API_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
